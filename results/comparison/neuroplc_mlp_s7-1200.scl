    IF v3[7] > 0.0 THEN v4[7] := v3[7]; ELSE v4[7] := 0.0; END_IF;
    IF v3[8] > 0.0 THEN v4[8] := v3[8]; ELSE v4[8] := 0.0; END_IF;
    IF v3[9] > 0.0 THEN v4[9] := v3[9]; ELSE v4[9] := 0.0; END_IF;
    IF v3[10] > 0.0 THEN v4[10] := v3[10]; ELSE v4[10] := 0.0; END_IF;
    IF v3[11] > 0.0 THEN v4[11] := v3[11]; ELSE v4[11] := 0.0; END_IF;
    IF v3[12] > 0.0 THEN v4[12] := v3[12]; ELSE v4[12] := 0.0; END_IF;
    IF v3[13] > 0.0 THEN v4[13] := v3[13]; ELSE v4[13] := 0.0; END_IF;
    IF v3[14] > 0.0 THEN v4[14] := v3[14]; ELSE v4[14] := 0.0; END_IF;
    IF v3[15] > 0.0 THEN v4[15] := v3[15]; ELSE v4[15] := 0.0; END_IF;

    // ---- fc2: MatMul(16→4) ----
    // W = "NeuroPLC_Weights".w2[:64],   b = w2[64:]
    v5[0] := "NeuroPLC_Weights".w2[64 + 0];
    FOR i := 0 TO 15 DO
        v5[0] := v5[0] + "NeuroPLC_Weights".w2[0 + i] * v4[i];
    END_FOR;
    v5[1] := "NeuroPLC_Weights".w2[64 + 1];
    FOR i := 0 TO 15 DO
        v5[1] := v5[1] + "NeuroPLC_Weights".w2[16 + i] * v4[i];
    END_FOR;
    v5[2] := "NeuroPLC_Weights".w2[64 + 2];
    FOR i := 0 TO 15 DO
        v5[2] := v5[2] + "NeuroPLC_Weights".w2[32 + i] * v4[i];
    END_FOR;
    v5[3] := "NeuroPLC_Weights".w2[64 + 3];
    FOR i := 0 TO 15 DO
        v5[3] := v5[3] + "NeuroPLC_Weights".w2[48 + i] * v4[i];
    END_FOR;

    // ---- softmax: Softmax ----
    v6[0] := EXP(v5[0]);
    v6[1] := EXP(v5[1]);
    v6[2] := EXP(v5[2]);
    v6[3] := EXP(v5[3]);
    sum_val := v6[0]
             + v6[1]
             + v6[2]
             + v6[3]
             ;
    IF sum_val > 0.0 THEN
        v6[0] := v6[0] / sum_val;
        v6[1] := v6[1] / sum_val;
        v6[2] := v6[2] / sum_val;
        v6[3] := v6[3] / sum_val;
    END_IF;

    // ---- Argmax ----
    max_val := v7[0];
    fault_class := 0;
    IF v7[1] > max_val THEN
        max_val := v7[1];
        fault_class := 1;
    END_IF;
    IF v7[2] > max_val THEN
        max_val := v7[2];
        fault_class := 2;
    END_IF;
    IF v7[3] > max_val THEN
        max_val := v7[3];
        fault_class := 3;
    END_IF;
    confidence := max_val;

END_FUNCTION_BLOCK