    v9[2] := EXP(v8[2]);
    v9[3] := EXP(v8[3]);
    sum_val := v9[0]
             + v9[1]
             + v9[2]
             + v9[3]
             ;
    IF sum_val > 0.0 THEN
        v9[0] := v9[0] / sum_val;
        v9[1] := v9[1] / sum_val;
        v9[2] := v9[2] / sum_val;
        v9[3] := v9[3] / sum_val;
    END_IF;

    // ---- Argmax ----
    max_val := v10[0];
