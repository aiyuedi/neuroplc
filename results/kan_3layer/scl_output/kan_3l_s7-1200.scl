    v3[10, 2] := "NeuroPLC_Weights".w1[4230 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w1[4230 + hi] * t_val;
    v3[11, 2] := "NeuroPLC_Weights".w1[4650 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w1[4650 + hi] * t_val;
    v3[12, 2] := "NeuroPLC_Weights".w1[5070 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w1[5070 + hi] * t_val;
    v3[13, 2] := "NeuroPLC_Weights".w1[5490 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w1[5490 + hi] * t_val;
