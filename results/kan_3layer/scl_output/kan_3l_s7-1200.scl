    // ---- l1_silu: SILU ----
    v5[0] := v4[0] / (1.0 + EXP(-v4[0]));
    v5[1] := v4[1] / (1.0 + EXP(-v4[1]));
    v5[2] := v4[2] / (1.0 + EXP(-v4[2]));
    v5[3] := v4[3] / (1.0 + EXP(-v4[3]));
    v5[4] := v4[4] / (1.0 + EXP(-v4[4]));
