    v4[13] := v2[13] + v3[13, 0] + v3[13, 1] + v3[13, 2] + v3[13, 3] + v3[13, 4] + v3[13, 5] + v3[13, 6] + v3[13, 7] + v3[13, 8] + v3[13, 9] + v3[13, 10] + v3[13, 11] + v3[13, 12] + v3[13, 13] + v3[13, 14] + v3[13, 15] + v3[13, 16] + v3[13, 17] + v3[13, 18] + v3[13, 19] + v3[13, 20] + v3[13, 21] + v3[13, 22] + v3[13, 23] + v3[13, 24] + v3[13, 25] + v3[13, 26] + v3[13, 27];
