    v5[13] := v4[13] / (1.0 + EXP(-v4[13]));
    v5[14] := v4[14] / (1.0 + EXP(-v4[14]));
    v5[15] := v4[15] / (1.0 + EXP(-v4[15]));

    // ---- l1_bspline: BsplineLUT(16x8, 15pts) HOISTED ----
    // Binary search ONCE per input, shared across outputs
    // --- Input 0: binary search ---
    lo := 0; hi := 14;
    WHILE hi - lo > 1 DO
