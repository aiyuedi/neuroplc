        IF v4[11] > "NeuroPLC_Weights".w3[mid] THEN lo := mid; ELSE hi := mid; END_IF;
    END_WHILE;
    t_val := (v4[11] - "NeuroPLC_Weights".w3[lo]) / ("NeuroPLC_Weights".w3[hi] - "NeuroPLC_Weights".w3[lo] + 1.0E-10);
    v7[0, 11] := "NeuroPLC_Weights".w4[165 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[165 + hi] * t_val;
    v7[1, 11] := "NeuroPLC_Weights".w4[405 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[405 + hi] * t_val;
    v7[2, 11] := "NeuroPLC_Weights".w4[645 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[645 + hi] * t_val;
    v7[3, 11] := "NeuroPLC_Weights".w4[885 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[885 + hi] * t_val;

    // --- Input 12: binary search ---
    lo := 0; hi := 14;
    WHILE hi - lo > 1 DO
        mid := lo + (hi - lo) / 2;
        IF v4[12] > "NeuroPLC_Weights".w3[mid] THEN lo := mid; ELSE hi := mid; END_IF;
    END_WHILE;
    t_val := (v4[12] - "NeuroPLC_Weights".w3[lo]) / ("NeuroPLC_Weights".w3[hi] - "NeuroPLC_Weights".w3[lo] + 1.0E-10);
    v7[0, 12] := "NeuroPLC_Weights".w4[180 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[180 + hi] * t_val;
    v7[1, 12] := "NeuroPLC_Weights".w4[420 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[420 + hi] * t_val;
    v7[2, 12] := "NeuroPLC_Weights".w4[660 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[660 + hi] * t_val;
    v7[3, 12] := "NeuroPLC_Weights".w4[900 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[900 + hi] * t_val;

    // --- Input 13: binary search ---
    lo := 0; hi := 14;
    WHILE hi - lo > 1 DO
        mid := lo + (hi - lo) / 2;
        IF v4[13] > "NeuroPLC_Weights".w3[mid] THEN lo := mid; ELSE hi := mid; END_IF;
    END_WHILE;
    t_val := (v4[13] - "NeuroPLC_Weights".w3[lo]) / ("NeuroPLC_Weights".w3[hi] - "NeuroPLC_Weights".w3[lo] + 1.0E-10);
    v7[0, 13] := "NeuroPLC_Weights".w4[195 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[195 + hi] * t_val;
    v7[1, 13] := "NeuroPLC_Weights".w4[435 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[435 + hi] * t_val;
    v7[2, 13] := "NeuroPLC_Weights".w4[675 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[675 + hi] * t_val;
    v7[3, 13] := "NeuroPLC_Weights".w4[915 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[915 + hi] * t_val;

    // --- Input 14: binary search ---
    lo := 0; hi := 14;
    WHILE hi - lo > 1 DO
        mid := lo + (hi - lo) / 2;
        IF v4[14] > "NeuroPLC_Weights".w3[mid] THEN lo := mid; ELSE hi := mid; END_IF;
    END_WHILE;
    t_val := (v4[14] - "NeuroPLC_Weights".w3[lo]) / ("NeuroPLC_Weights".w3[hi] - "NeuroPLC_Weights".w3[lo] + 1.0E-10);
    v7[0, 14] := "NeuroPLC_Weights".w4[210 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[210 + hi] * t_val;
    v7[1, 14] := "NeuroPLC_Weights".w4[450 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[450 + hi] * t_val;
    v7[2, 14] := "NeuroPLC_Weights".w4[690 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[690 + hi] * t_val;
    v7[3, 14] := "NeuroPLC_Weights".w4[930 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[930 + hi] * t_val;

    // --- Input 15: binary search ---
    lo := 0; hi := 14;
    WHILE hi - lo > 1 DO
        mid := lo + (hi - lo) / 2;
        IF v4[15] > "NeuroPLC_Weights".w3[mid] THEN lo := mid; ELSE hi := mid; END_IF;
    END_WHILE;
    t_val := (v4[15] - "NeuroPLC_Weights".w3[lo]) / ("NeuroPLC_Weights".w3[hi] - "NeuroPLC_Weights".w3[lo] + 1.0E-10);
    v7[0, 15] := "NeuroPLC_Weights".w4[225 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[225 + hi] * t_val;
    v7[1, 15] := "NeuroPLC_Weights".w4[465 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[465 + hi] * t_val;
    v7[2, 15] := "NeuroPLC_Weights".w4[705 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[705 + hi] * t_val;
    v7[3, 15] := "NeuroPLC_Weights".w4[945 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[945 + hi] * t_val;


    // ---- l1_base: MatMul(16→4) ----
    // W = "NeuroPLC_Weights".w5[:64],   b = w5[64:]
    v6[0] := "NeuroPLC_Weights".w5[64 + 0];
    FOR i := 0 TO 15 DO
        v6[0] := v6[0] + "NeuroPLC_Weights".w5[0 + i] * v5[i];
    END_FOR;
    v6[1] := "NeuroPLC_Weights".w5[64 + 1];
    FOR i := 0 TO 15 DO
        v6[1] := v6[1] + "NeuroPLC_Weights".w5[16 + i] * v5[i];
    END_FOR;
    v6[2] := "NeuroPLC_Weights".w5[64 + 2];
    FOR i := 0 TO 15 DO
        v6[2] := v6[2] + "NeuroPLC_Weights".w5[32 + i] * v5[i];
    END_FOR;
    v6[3] := "NeuroPLC_Weights".w5[64 + 3];
    FOR i := 0 TO 15 DO
        v6[3] := v6[3] + "NeuroPLC_Weights".w5[48 + i] * v5[i];
    END_FOR;

    // ---- l1_merge: Add (KAN merge) ----
    v8[0] := v6[0] + v7[0, 0] + v7[0, 1] + v7[0, 2] + v7[0, 3] + v7[0, 4] + v7[0, 5] + v7[0, 6] + v7[0, 7] + v7[0, 8] + v7[0, 9] + v7[0, 10] + v7[0, 11] + v7[0, 12] + v7[0, 13] + v7[0, 14] + v7[0, 15];
    v8[1] := v6[1] + v7[1, 0] + v7[1, 1] + v7[1, 2] + v7[1, 3] + v7[1, 4] + v7[1, 5] + v7[1, 6] + v7[1, 7] + v7[1, 8] + v7[1, 9] + v7[1, 10] + v7[1, 11] + v7[1, 12] + v7[1, 13] + v7[1, 14] + v7[1, 15];
    v8[2] := v6[2] + v7[2, 0] + v7[2, 1] + v7[2, 2] + v7[2, 3] + v7[2, 4] + v7[2, 5] + v7[2, 6] + v7[2, 7] + v7[2, 8] + v7[2, 9] + v7[2, 10] + v7[2, 11] + v7[2, 12] + v7[2, 13] + v7[2, 14] + v7[2, 15];
    v8[3] := v6[3] + v7[3, 0] + v7[3, 1] + v7[3, 2] + v7[3, 3] + v7[3, 4] + v7[3, 5] + v7[3, 6] + v7[3, 7] + v7[3, 8] + v7[3, 9] + v7[3, 10] + v7[3, 11] + v7[3, 12] + v7[3, 13] + v7[3, 14] + v7[3, 15];

    // ---- softmax: Softmax ----
    v9[0] := EXP(v8[0]);
    v9[1] := EXP(v8[1]);
    v9[2] := EXP(v8[2]);
    v9[3] := EXP(v8[3]);
    sum_val := v9[0]
             + v9[1]
             + v9[2]
             + v9[3]
             ;
    IF sum_val > 0.0 THEN
        v9[0] := v9[0] / sum_val;
        v9[1] := v9[1] / sum_val;
        v9[2] := v9[2] / sum_val;
        v9[3] := v9[3] / sum_val;
    END_IF;

    // ---- Argmax ----
    max_val := v10[0];
    fault_class := 0;
    IF v10[1] > max_val THEN
        max_val := v10[1];
        fault_class := 1;
    END_IF;
    IF v10[2] > max_val THEN
        max_val := v10[2];
        fault_class := 2;
    END_IF;
    IF v10[3] > max_val THEN
        max_val := v10[3];
        fault_class := 3;
    END_IF;
    confidence := max_val;

END_FUNCTION_BLOCK