    // ---- l1_merge: Add (KAN merge) ----
    v8[0] := v6[0] + v7[0, 0] + v7[0, 1] + v7[0, 2] + v7[0, 3] + v7[0, 4] + v7[0, 5] + v7[0, 6] + v7[0, 7] + v7[0, 8] + v7[0, 9] + v7[0, 10] + v7[0, 11] + v7[0, 12] + v7[0, 13] + v7[0, 14] + v7[0, 15];
    v8[1] := v6[1] + v7[1, 0] + v7[1, 1] + v7[1, 2] + v7[1, 3] + v7[1, 4] + v7[1, 5] + v7[1, 6] + v7[1, 7] + v7[1, 8] + v7[1, 9] + v7[1, 10] + v7[1, 11] + v7[1, 12] + v7[1, 13] + v7[1, 14] + v7[1, 15];
    v8[2] := v6[2] + v7[2, 0] + v7[2, 1] + v7[2, 2] + v7[2, 3] + v7[2, 4] + v7[2, 5] + v7[2, 6] + v7[2, 7] + v7[2, 8] + v7[2, 9] + v7[2, 10] + v7[2, 11] + v7[2, 12] + v7[2, 13] + v7[2, 14] + v7[2, 15];
    v8[3] := v6[3] + v7[3, 0] + v7[3, 1] + v7[3, 2] + v7[3, 3] + v7[3, 4] + v7[3, 5] + v7[3, 6] + v7[3, 7] + v7[3, 8] + v7[3, 9] + v7[3, 10] + v7[3, 11] + v7[3, 12] + v7[3, 13] + v7[3, 14] + v7[3, 15];
    v8[4] := v6[4] + v7[4, 0] + v7[4, 1] + v7[4, 2] + v7[4, 3] + v7[4, 4] + v7[4, 5] + v7[4, 6] + v7[4, 7] + v7[4, 8] + v7[4, 9] + v7[4, 10] + v7[4, 11] + v7[4, 12] + v7[4, 13] + v7[4, 14] + v7[4, 15];
    v8[5] := v6[5] + v7[5, 0] + v7[5, 1] + v7[5, 2] + v7[5, 3] + v7[5, 4] + v7[5, 5] + v7[5, 6] + v7[5, 7] + v7[5, 8] + v7[5, 9] + v7[5, 10] + v7[5, 11] + v7[5, 12] + v7[5, 13] + v7[5, 14] + v7[5, 15];
    v8[6] := v6[6] + v7[6, 0] + v7[6, 1] + v7[6, 2] + v7[6, 3] + v7[6, 4] + v7[6, 5] + v7[6, 6] + v7[6, 7] + v7[6, 8] + v7[6, 9] + v7[6, 10] + v7[6, 11] + v7[6, 12] + v7[6, 13] + v7[6, 14] + v7[6, 15];
    v8[7] := v6[7] + v7[7, 0] + v7[7, 1] + v7[7, 2] + v7[7, 3] + v7[7, 4] + v7[7, 5] + v7[7, 6] + v7[7, 7] + v7[7, 8] + v7[7, 9] + v7[7, 10] + v7[7, 11] + v7[7, 12] + v7[7, 13] + v7[7, 14] + v7[7, 15];

    // ---- l2_silu: SILU ----
    v9[0] := v8[0] / (1.0 + EXP(-v8[0]));
    v9[1] := v8[1] / (1.0 + EXP(-v8[1]));
    v9[2] := v8[2] / (1.0 + EXP(-v8[2]));
    v9[3] := v8[3] / (1.0 + EXP(-v8[3]));
    v9[4] := v8[4] / (1.0 + EXP(-v8[4]));
    v9[5] := v8[5] / (1.0 + EXP(-v8[5]));
    v9[6] := v8[6] / (1.0 + EXP(-v8[6]));
    v9[7] := v8[7] / (1.0 + EXP(-v8[7]));

    // ---- l2_bspline: BsplineLUT(8x4, 15pts) HOISTED ----
    // Binary search ONCE per input, shared across outputs
    // --- Input 0: binary search ---
    lo := 0; hi := 14;
    WHILE hi - lo > 1 DO
        mid := lo + (hi - lo) / 2;
        IF v8[0] > "NeuroPLC_Weights".w6[mid] THEN lo := mid; ELSE hi := mid; END_IF;
    END_WHILE;
    t_val := (v8[0] - "NeuroPLC_Weights".w6[lo]) / ("NeuroPLC_Weights".w6[hi] - "NeuroPLC_Weights".w6[lo] + 1.0E-10);
    v11[0, 0] := "NeuroPLC_Weights".w7[0 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w7[0 + hi] * t_val;
    v11[1, 0] := "NeuroPLC_Weights".w7[120 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w7[120 + hi] * t_val;
    v11[2, 0] := "NeuroPLC_Weights".w7[240 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w7[240 + hi] * t_val;
    v11[3, 0] := "NeuroPLC_Weights".w7[360 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w7[360 + hi] * t_val;

    // --- Input 1: binary search ---
    lo := 0; hi := 14;
    WHILE hi - lo > 1 DO
        mid := lo + (hi - lo) / 2;
        IF v8[1] > "NeuroPLC_Weights".w6[mid] THEN lo := mid; ELSE hi := mid; END_IF;
    END_WHILE;
    t_val := (v8[1] - "NeuroPLC_Weights".w6[lo]) / ("NeuroPLC_Weights".w6[hi] - "NeuroPLC_Weights".w6[lo] + 1.0E-10);
    v11[0, 1] := "NeuroPLC_Weights".w7[15 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w7[15 + hi] * t_val;
    v11[1, 1] := "NeuroPLC_Weights".w7[135 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w7[135 + hi] * t_val;
    v11[2, 1] := "NeuroPLC_Weights".w7[255 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w7[255 + hi] * t_val;
    v11[3, 1] := "NeuroPLC_Weights".w7[375 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w7[375 + hi] * t_val;

    // --- Input 2: binary search ---
    lo := 0; hi := 14;
    WHILE hi - lo > 1 DO
        mid := lo + (hi - lo) / 2;
        IF v8[2] > "NeuroPLC_Weights".w6[mid] THEN lo := mid; ELSE hi := mid; END_IF;
    END_WHILE;
    t_val := (v8[2] - "NeuroPLC_Weights".w6[lo]) / ("NeuroPLC_Weights".w6[hi] - "NeuroPLC_Weights".w6[lo] + 1.0E-10);
    v11[0, 2] := "NeuroPLC_Weights".w7[30 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w7[30 + hi] * t_val;
    v11[1, 2] := "NeuroPLC_Weights".w7[150 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w7[150 + hi] * t_val;
    v11[2, 2] := "NeuroPLC_Weights".w7[270 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w7[270 + hi] * t_val;
    v11[3, 2] := "NeuroPLC_Weights".w7[390 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w7[390 + hi] * t_val;

    // --- Input 3: binary search ---
    lo := 0; hi := 14;
    WHILE hi - lo > 1 DO
        mid := lo + (hi - lo) / 2;
        IF v8[3] > "NeuroPLC_Weights".w6[mid] THEN lo := mid; ELSE hi := mid; END_IF;
    END_WHILE;
    t_val := (v8[3] - "NeuroPLC_Weights".w6[lo]) / ("NeuroPLC_Weights".w6[hi] - "NeuroPLC_Weights".w6[lo] + 1.0E-10);
    v11[0, 3] := "NeuroPLC_Weights".w7[45 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w7[45 + hi] * t_val;
    v11[1, 3] := "NeuroPLC_Weights".w7[165 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w7[165 + hi] * t_val;
    v11[2, 3] := "NeuroPLC_Weights".w7[285 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w7[285 + hi] * t_val;
    v11[3, 3] := "NeuroPLC_Weights".w7[405 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w7[405 + hi] * t_val;

    // --- Input 4: binary search ---
    lo := 0; hi := 14;
    WHILE hi - lo > 1 DO
        mid := lo + (hi - lo) / 2;
        IF v8[4] > "NeuroPLC_Weights".w6[mid] THEN lo := mid; ELSE hi := mid; END_IF;
    END_WHILE;
    t_val := (v8[4] - "NeuroPLC_Weights".w6[lo]) / ("NeuroPLC_Weights".w6[hi] - "NeuroPLC_Weights".w6[lo] + 1.0E-10);
    v11[0, 4] := "NeuroPLC_Weights".w7[60 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w7[60 + hi] * t_val;
    v11[1, 4] := "NeuroPLC_Weights".w7[180 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w7[180 + hi] * t_val;
    v11[2, 4] := "NeuroPLC_Weights".w7[300 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w7[300 + hi] * t_val;
    v11[3, 4] := "NeuroPLC_Weights".w7[420 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w7[420 + hi] * t_val;

    // --- Input 5: binary search ---
    lo := 0; hi := 14;
    WHILE hi - lo > 1 DO
        mid := lo + (hi - lo) / 2;
        IF v8[5] > "NeuroPLC_Weights".w6[mid] THEN lo := mid; ELSE hi := mid; END_IF;
    END_WHILE;
    t_val := (v8[5] - "NeuroPLC_Weights".w6[lo]) / ("NeuroPLC_Weights".w6[hi] - "NeuroPLC_Weights".w6[lo] + 1.0E-10);
    v11[0, 5] := "NeuroPLC_Weights".w7[75 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w7[75 + hi] * t_val;
    v11[1, 5] := "NeuroPLC_Weights".w7[195 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w7[195 + hi] * t_val;
    v11[2, 5] := "NeuroPLC_Weights".w7[315 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w7[315 + hi] * t_val;
    v11[3, 5] := "NeuroPLC_Weights".w7[435 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w7[435 + hi] * t_val;

    // --- Input 6: binary search ---
    lo := 0; hi := 14;
    WHILE hi - lo > 1 DO
        mid := lo + (hi - lo) / 2;
        IF v8[6] > "NeuroPLC_Weights".w6[mid] THEN lo := mid; ELSE hi := mid; END_IF;
    END_WHILE;
    t_val := (v8[6] - "NeuroPLC_Weights".w6[lo]) / ("NeuroPLC_Weights".w6[hi] - "NeuroPLC_Weights".w6[lo] + 1.0E-10);
    v11[0, 6] := "NeuroPLC_Weights".w7[90 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w7[90 + hi] * t_val;
    v11[1, 6] := "NeuroPLC_Weights".w7[210 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w7[210 + hi] * t_val;
    v11[2, 6] := "NeuroPLC_Weights".w7[330 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w7[330 + hi] * t_val;
    v11[3, 6] := "NeuroPLC_Weights".w7[450 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w7[450 + hi] * t_val;

    // --- Input 7: binary search ---
    lo := 0; hi := 14;
    WHILE hi - lo > 1 DO
        mid := lo + (hi - lo) / 2;
        IF v8[7] > "NeuroPLC_Weights".w6[mid] THEN lo := mid; ELSE hi := mid; END_IF;
    END_WHILE;
    t_val := (v8[7] - "NeuroPLC_Weights".w6[lo]) / ("NeuroPLC_Weights".w6[hi] - "NeuroPLC_Weights".w6[lo] + 1.0E-10);
    v11[0, 7] := "NeuroPLC_Weights".w7[105 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w7[105 + hi] * t_val;
    v11[1, 7] := "NeuroPLC_Weights".w7[225 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w7[225 + hi] * t_val;
    v11[2, 7] := "NeuroPLC_Weights".w7[345 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w7[345 + hi] * t_val;
    v11[3, 7] := "NeuroPLC_Weights".w7[465 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w7[465 + hi] * t_val;


    // ---- l2_base: MatMul(8→4) ----
    // W = "NeuroPLC_Weights".w8[:32],   b = w8[32:]
    v10[0] := "NeuroPLC_Weights".w8[32 + 0];
    FOR i := 0 TO 7 DO
        v10[0] := v10[0] + "NeuroPLC_Weights".w8[0 + i] * v9[i];
    END_FOR;
    v10[1] := "NeuroPLC_Weights".w8[32 + 1];
    FOR i := 0 TO 7 DO
        v10[1] := v10[1] + "NeuroPLC_Weights".w8[8 + i] * v9[i];
    END_FOR;
    v10[2] := "NeuroPLC_Weights".w8[32 + 2];
    FOR i := 0 TO 7 DO
        v10[2] := v10[2] + "NeuroPLC_Weights".w8[16 + i] * v9[i];
    END_FOR;
    v10[3] := "NeuroPLC_Weights".w8[32 + 3];
    FOR i := 0 TO 7 DO
        v10[3] := v10[3] + "NeuroPLC_Weights".w8[24 + i] * v9[i];
    END_FOR;

    // ---- l2_merge: Add (KAN merge) ----
    v12[0] := v10[0] + v11[0, 0] + v11[0, 1] + v11[0, 2] + v11[0, 3] + v11[0, 4] + v11[0, 5] + v11[0, 6] + v11[0, 7];
    v12[1] := v10[1] + v11[1, 0] + v11[1, 1] + v11[1, 2] + v11[1, 3] + v11[1, 4] + v11[1, 5] + v11[1, 6] + v11[1, 7];
    v12[2] := v10[2] + v11[2, 0] + v11[2, 1] + v11[2, 2] + v11[2, 3] + v11[2, 4] + v11[2, 5] + v11[2, 6] + v11[2, 7];
    v12[3] := v10[3] + v11[3, 0] + v11[3, 1] + v11[3, 2] + v11[3, 3] + v11[3, 4] + v11[3, 5] + v11[3, 6] + v11[3, 7];

    // ---- softmax: Softmax ----
    v13[0] := EXP(v12[0]);
    v13[1] := EXP(v12[1]);
    v13[2] := EXP(v12[2]);
    v13[3] := EXP(v12[3]);
    sum_val := v13[0]
             + v13[1]
             + v13[2]
             + v13[3]
             ;
    IF sum_val > 0.0 THEN
        v13[0] := v13[0] / sum_val;
        v13[1] := v13[1] / sum_val;
        v13[2] := v13[2] / sum_val;
        v13[3] := v13[3] / sum_val;
    END_IF;

    // ---- Argmax ----
    max_val := v14[0];
    fault_class := 0;
    IF v14[1] > max_val THEN
        max_val := v14[1];
        fault_class := 1;
    END_IF;
    IF v14[2] > max_val THEN
        max_val := v14[2];
        fault_class := 2;
    END_IF;
    IF v14[3] > max_val THEN
        max_val := v14[3];
        fault_class := 3;
    END_IF;
    confidence := max_val;

END_FUNCTION_BLOCK