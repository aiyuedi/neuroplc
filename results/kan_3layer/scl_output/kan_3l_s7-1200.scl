    v7[1, 3] := "NeuroPLC_Weights".w4[285 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[285 + hi] * t_val;
    v7[2, 3] := "NeuroPLC_Weights".w4[525 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[525 + hi] * t_val;
    v7[3, 3] := "NeuroPLC_Weights".w4[765 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[765 + hi] * t_val;
