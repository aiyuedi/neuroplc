    lo := 0; hi := 14;
    WHILE hi - lo > 1 DO
        mid := lo + (hi - lo) / 2;
        IF v4[1] > "NeuroPLC_Weights".w3[mid] THEN lo := mid; ELSE hi := mid; END_IF;
    END_WHILE;
    t_val := (v4[1] - "NeuroPLC_Weights".w3[lo]) / ("NeuroPLC_Weights".w3[hi] - "NeuroPLC_Weights".w3[lo] + 1.0E-10);
    v7[0, 1] := "NeuroPLC_Weights".w4[15 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[15 + hi] * t_val;
    v7[1, 1] := "NeuroPLC_Weights".w4[255 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[255 + hi] * t_val;
    v7[2, 1] := "NeuroPLC_Weights".w4[495 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[495 + hi] * t_val;
    v7[3, 1] := "NeuroPLC_Weights".w4[735 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[735 + hi] * t_val;
    v7[4, 1] := "NeuroPLC_Weights".w4[975 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[975 + hi] * t_val;
    v7[5, 1] := "NeuroPLC_Weights".w4[1215 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[1215 + hi] * t_val;
    v7[6, 1] := "NeuroPLC_Weights".w4[1455 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[1455 + hi] * t_val;
    v7[7, 1] := "NeuroPLC_Weights".w4[1695 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[1695 + hi] * t_val;

    // --- Input 2: binary search ---
    lo := 0; hi := 14;
    WHILE hi - lo > 1 DO
        mid := lo + (hi - lo) / 2;
        IF v4[2] > "NeuroPLC_Weights".w3[mid] THEN lo := mid; ELSE hi := mid; END_IF;
    END_WHILE;
    t_val := (v4[2] - "NeuroPLC_Weights".w3[lo]) / ("NeuroPLC_Weights".w3[hi] - "NeuroPLC_Weights".w3[lo] + 1.0E-10);
    v7[0, 2] := "NeuroPLC_Weights".w4[30 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[30 + hi] * t_val;
    v7[1, 2] := "NeuroPLC_Weights".w4[270 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[270 + hi] * t_val;
    v7[2, 2] := "NeuroPLC_Weights".w4[510 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[510 + hi] * t_val;
    v7[3, 2] := "NeuroPLC_Weights".w4[750 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[750 + hi] * t_val;
    v7[4, 2] := "NeuroPLC_Weights".w4[990 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w4[990 + hi] * t_val;
