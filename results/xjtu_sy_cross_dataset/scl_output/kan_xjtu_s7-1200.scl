FUNCTION "BsplineEval" : REAL
{ S7_Optimized_Access := 'FALSE' }
VERSION : 0.1
VAR_INPUT
    x : REAL;
    lut_grid : ARRAY[0..14] OF REAL;
    lut_table : ARRAY[0..14] OF REAL;
END_VAR
VAR_TEMP
    lo, hi, mid : INT;
    t, vlo, vhi : REAL;
END_VAR

BEGIN
    // Binary search for interval containing x
    lo := 0;
    hi := 14;
    WHILE hi - lo > 1 DO
        mid := lo + (hi - lo) / 2;
        IF x > lut_grid[mid] THEN lo := mid; ELSE hi := mid; END_IF;
    END_WHILE;

    // Linear interpolation: y = vlo*(1-t) + vhi*t
    vlo := lut_table[lo];
    vhi := lut_table[hi];
    t := (x - lut_grid[lo]) / (lut_grid[hi] - lut_grid[lo] + 1.0E-10);
    "BsplineEval" := vlo * (1.0 - t) + vhi * t;
END_FUNCTION

FUNCTION_BLOCK "NeuroPLC_Inference"
{ S7_Optimized_Access := 'FALSE' }
VERSION : 0.1
VAR_INPUT
    features : ARRAY[0..27] OF REAL;
END_VAR

VAR_OUTPUT
    fault_class : INT;
    confidence : REAL;
END_VAR

VAR
    i, j, k : INT;
    sum_val, max_val, t_val : REAL;
    v0 : ARRAY[0..27] OF REAL;
    v1 : ARRAY[0..27] OF REAL;
    v3 : ARRAY[0..15, 0..27] OF REAL;
    v2 : ARRAY[0..15] OF REAL;
    v4 : ARRAY[0..15] OF REAL;
    v5 : ARRAY[0..15] OF REAL;
    v7 : ARRAY[0..3, 0..15] OF REAL;
    v6 : ARRAY[0..3] OF REAL;
    v8 : ARRAY[0..3] OF REAL;
    v9 : ARRAY[0..3] OF REAL;
    lut_tmp : ARRAY[0..14] OF REAL;
END_VAR

BEGIN
    // ---- Input ----
    FOR i := 0 TO 27 DO
        v0[i] := features[i];
    END_FOR;

    // ---- l0_silu: SILU ----
    v1[0] := v0[0] / (1.0 + EXP(-v0[0]));
    v1[1] := v0[1] / (1.0 + EXP(-v0[1]));
    v1[2] := v0[2] / (1.0 + EXP(-v0[2]));
    v1[3] := v0[3] / (1.0 + EXP(-v0[3]));
    v1[4] := v0[4] / (1.0 + EXP(-v0[4]));
    v1[5] := v0[5] / (1.0 + EXP(-v0[5]));
    v1[6] := v0[6] / (1.0 + EXP(-v0[6]));
    v1[7] := v0[7] / (1.0 + EXP(-v0[7]));
    v1[8] := v0[8] / (1.0 + EXP(-v0[8]));
    v1[9] := v0[9] / (1.0 + EXP(-v0[9]));
    v1[10] := v0[10] / (1.0 + EXP(-v0[10]));
    v1[11] := v0[11] / (1.0 + EXP(-v0[11]));
    v1[12] := v0[12] / (1.0 + EXP(-v0[12]));
    v1[13] := v0[13] / (1.0 + EXP(-v0[13]));
    v1[14] := v0[14] / (1.0 + EXP(-v0[14]));
    v1[15] := v0[15] / (1.0 + EXP(-v0[15]));
    v1[16] := v0[16] / (1.0 + EXP(-v0[16]));
    v1[17] := v0[17] / (1.0 + EXP(-v0[17]));
    v1[18] := v0[18] / (1.0 + EXP(-v0[18]));
    v1[19] := v0[19] / (1.0 + EXP(-v0[19]));
    v1[20] := v0[20] / (1.0 + EXP(-v0[20]));
    v1[21] := v0[21] / (1.0 + EXP(-v0[21]));
    v1[22] := v0[22] / (1.0 + EXP(-v0[22]));
    v1[23] := v0[23] / (1.0 + EXP(-v0[23]));
    v1[24] := v0[24] / (1.0 + EXP(-v0[24]));
    v1[25] := v0[25] / (1.0 + EXP(-v0[25]));
    v1[26] := v0[26] / (1.0 + EXP(-v0[26]));
    v1[27] := v0[27] / (1.0 + EXP(-v0[27]));

    // ---- l0_bspline: BsplineLUT(28x16, 15pts) HOISTED ----
    // Binary search ONCE per input, shared across outputs
    // --- Input 0: binary search ---
    lo := 0; hi := 14;
    WHILE hi - lo > 1 DO
        mid := lo + (hi - lo) / 2;
        IF v0[0] > "NeuroPLC_Weights".w0[mid] THEN lo := mid; ELSE hi := mid; END_IF;
    END_WHILE;
    t_val := (v0[0] - "NeuroPLC_Weights".w0[lo]) / ("NeuroPLC_Weights".w0[hi] - "NeuroPLC_Weights".w0[lo] + 1.0E-10);
    v3[0, 0] := "NeuroPLC_Weights".w1[0 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w1[0 + hi] * t_val;
    v3[1, 0] := "NeuroPLC_Weights".w1[420 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w1[420 + hi] * t_val;
    v3[2, 0] := "NeuroPLC_Weights".w1[840 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w1[840 + hi] * t_val;
    v3[3, 0] := "NeuroPLC_Weights".w1[1260 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w1[1260 + hi] * t_val;
    v3[4, 0] := "NeuroPLC_Weights".w1[1680 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w1[1680 + hi] * t_val;
    v3[5, 0] := "NeuroPLC_Weights".w1[2100 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w1[2100 + hi] * t_val;
    v3[6, 0] := "NeuroPLC_Weights".w1[2520 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w1[2520 + hi] * t_val;
    v3[7, 0] := "NeuroPLC_Weights".w1[2940 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w1[2940 + hi] * t_val;
    v3[8, 0] := "NeuroPLC_Weights".w1[3360 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w1[3360 + hi] * t_val;
    v3[9, 0] := "NeuroPLC_Weights".w1[3780 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w1[3780 + hi] * t_val;
    v3[10, 0] := "NeuroPLC_Weights".w1[4200 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w1[4200 + hi] * t_val;
