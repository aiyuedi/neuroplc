    v4[8] := v2[8] + v3[8, 0] + v3[8, 1] + v3[8, 2] + v3[8, 3] + v3[8, 4] + v3[8, 5] + v3[8, 6] + v3[8, 7] + v3[8, 8] + v3[8, 9] + v3[8, 10] + v3[8, 11] + v3[8, 12] + v3[8, 13] + v3[8, 14] + v3[8, 15] + v3[8, 16] + v3[8, 17] + v3[8, 18] + v3[8, 19] + v3[8, 20] + v3[8, 21] + v3[8, 22] + v3[8, 23] + v3[8, 24] + v3[8, 25] + v3[8, 26] + v3[8, 27];
