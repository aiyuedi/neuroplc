    // ---- l0_merge: Add (KAN merge) ----
    v4[0] := v2[0] + v3[0, 0] + v3[0, 1] + v3[0, 2] + v3[0, 3] + v3[0, 4] + v3[0, 5] + v3[0, 6] + v3[0, 7] + v3[0, 8] + v3[0, 9] + v3[0, 10] + v3[0, 11] + v3[0, 12] + v3[0, 13] + v3[0, 14] + v3[0, 15] + v3[0, 16] + v3[0, 17] + v3[0, 18] + v3[0, 19] + v3[0, 20] + v3[0, 21] + v3[0, 22] + v3[0, 23] + v3[0, 24] + v3[0, 25] + v3[0, 26] + v3[0, 27];
    v4[1] := v2[1] + v3[1, 0] + v3[1, 1] + v3[1, 2] + v3[1, 3] + v3[1, 4] + v3[1, 5] + v3[1, 6] + v3[1, 7] + v3[1, 8] + v3[1, 9] + v3[1, 10] + v3[1, 11] + v3[1, 12] + v3[1, 13] + v3[1, 14] + v3[1, 15] + v3[1, 16] + v3[1, 17] + v3[1, 18] + v3[1, 19] + v3[1, 20] + v3[1, 21] + v3[1, 22] + v3[1, 23] + v3[1, 24] + v3[1, 25] + v3[1, 26] + v3[1, 27];
    v4[2] := v2[2] + v3[2, 0] + v3[2, 1] + v3[2, 2] + v3[2, 3] + v3[2, 4] + v3[2, 5] + v3[2, 6] + v3[2, 7] + v3[2, 8] + v3[2, 9] + v3[2, 10] + v3[2, 11] + v3[2, 12] + v3[2, 13] + v3[2, 14] + v3[2, 15] + v3[2, 16] + v3[2, 17] + v3[2, 18] + v3[2, 19] + v3[2, 20] + v3[2, 21] + v3[2, 22] + v3[2, 23] + v3[2, 24] + v3[2, 25] + v3[2, 26] + v3[2, 27];
    v4[3] := v2[3] + v3[3, 0] + v3[3, 1] + v3[3, 2] + v3[3, 3] + v3[3, 4] + v3[3, 5] + v3[3, 6] + v3[3, 7] + v3[3, 8] + v3[3, 9] + v3[3, 10] + v3[3, 11] + v3[3, 12] + v3[3, 13] + v3[3, 14] + v3[3, 15] + v3[3, 16] + v3[3, 17] + v3[3, 18] + v3[3, 19] + v3[3, 20] + v3[3, 21] + v3[3, 22] + v3[3, 23] + v3[3, 24] + v3[3, 25] + v3[3, 26] + v3[3, 27];
