    v3[14, 1] := "NeuroPLC_Weights".w1[19650 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w1[19650 + hi] * t_val;
    v3[15, 1] := "NeuroPLC_Weights".w1[21050 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w1[21050 + hi] * t_val;

    // --- Input 2: binary search ---
    lo := 0; hi := 49;
    WHILE hi - lo > 1 DO
        mid := lo + (hi - lo) / 2;
        IF v0[2] > "NeuroPLC_Weights".w0[mid] THEN lo := mid; ELSE hi := mid; END_IF;
    END_WHILE;
    t_val := (v0[2] - "NeuroPLC_Weights".w0[lo]) / ("NeuroPLC_Weights".w0[hi] - "NeuroPLC_Weights".w0[lo] + 1.0E-10);
    v3[0, 2] := "NeuroPLC_Weights".w1[100 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w1[100 + hi] * t_val;
    v3[1, 2] := "NeuroPLC_Weights".w1[1500 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w1[1500 + hi] * t_val;
    v3[2, 2] := "NeuroPLC_Weights".w1[2900 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w1[2900 + hi] * t_val;
    v3[3, 2] := "NeuroPLC_Weights".w1[4300 + lo] * (1.0 - t_val) + "NeuroPLC_Weights".w1[4300 + hi] * t_val;
