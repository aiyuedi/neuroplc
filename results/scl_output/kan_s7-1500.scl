    v6[0] := "NeuroPLC_Weights".w5[64 + 0] + "NeuroPLC_Weights".w5[0] * v5[0] + "NeuroPLC_Weights".w5[1] * v5[1] + "NeuroPLC_Weights".w5[2] * v5[2] + "NeuroPLC_Weights".w5[3] * v5[3] + "NeuroPLC_Weights".w5[4] * v5[4] + "NeuroPLC_Weights".w5[5] * v5[5] + "NeuroPLC_Weights".w5[6] * v5[6] + "NeuroPLC_Weights".w5[7] * v5[7] + "NeuroPLC_Weights".w5[8] * v5[8] + "NeuroPLC_Weights".w5[9] * v5[9] + "NeuroPLC_Weights".w5[10] * v5[10] + "NeuroPLC_Weights".w5[11] * v5[11] + "NeuroPLC_Weights".w5[12] * v5[12] + "NeuroPLC_Weights".w5[13] * v5[13] + "NeuroPLC_Weights".w5[14] * v5[14] + "NeuroPLC_Weights".w5[15] * v5[15];
    v6[1] := "NeuroPLC_Weights".w5[64 + 1] + "NeuroPLC_Weights".w5[16] * v5[0] + "NeuroPLC_Weights".w5[17] * v5[1] + "NeuroPLC_Weights".w5[18] * v5[2] + "NeuroPLC_Weights".w5[19] * v5[3] + "NeuroPLC_Weights".w5[20] * v5[4] + "NeuroPLC_Weights".w5[21] * v5[5] + "NeuroPLC_Weights".w5[22] * v5[6] + "NeuroPLC_Weights".w5[23] * v5[7] + "NeuroPLC_Weights".w5[24] * v5[8] + "NeuroPLC_Weights".w5[25] * v5[9] + "NeuroPLC_Weights".w5[26] * v5[10] + "NeuroPLC_Weights".w5[27] * v5[11] + "NeuroPLC_Weights".w5[28] * v5[12] + "NeuroPLC_Weights".w5[29] * v5[13] + "NeuroPLC_Weights".w5[30] * v5[14] + "NeuroPLC_Weights".w5[31] * v5[15];
    v6[2] := "NeuroPLC_Weights".w5[64 + 2] + "NeuroPLC_Weights".w5[32] * v5[0] + "NeuroPLC_Weights".w5[33] * v5[1] + "NeuroPLC_Weights".w5[34] * v5[2] + "NeuroPLC_Weights".w5[35] * v5[3] + "NeuroPLC_Weights".w5[36] * v5[4] + "NeuroPLC_Weights".w5[37] * v5[5] + "NeuroPLC_Weights".w5[38] * v5[6] + "NeuroPLC_Weights".w5[39] * v5[7] + "NeuroPLC_Weights".w5[40] * v5[8] + "NeuroPLC_Weights".w5[41] * v5[9] + "NeuroPLC_Weights".w5[42] * v5[10] + "NeuroPLC_Weights".w5[43] * v5[11] + "NeuroPLC_Weights".w5[44] * v5[12] + "NeuroPLC_Weights".w5[45] * v5[13] + "NeuroPLC_Weights".w5[46] * v5[14] + "NeuroPLC_Weights".w5[47] * v5[15];
    v6[3] := "NeuroPLC_Weights".w5[64 + 3] + "NeuroPLC_Weights".w5[48] * v5[0] + "NeuroPLC_Weights".w5[49] * v5[1] + "NeuroPLC_Weights".w5[50] * v5[2] + "NeuroPLC_Weights".w5[51] * v5[3] + "NeuroPLC_Weights".w5[52] * v5[4] + "NeuroPLC_Weights".w5[53] * v5[5] + "NeuroPLC_Weights".w5[54] * v5[6] + "NeuroPLC_Weights".w5[55] * v5[7] + "NeuroPLC_Weights".w5[56] * v5[8] + "NeuroPLC_Weights".w5[57] * v5[9] + "NeuroPLC_Weights".w5[58] * v5[10] + "NeuroPLC_Weights".w5[59] * v5[11] + "NeuroPLC_Weights".w5[60] * v5[12] + "NeuroPLC_Weights".w5[61] * v5[13] + "NeuroPLC_Weights".w5[62] * v5[14] + "NeuroPLC_Weights".w5[63] * v5[15];

    // ---- l1_merge: Add (KAN merge) ----
    v8[0] := v6[0] + v7[0, 0] + v7[0, 1] + v7[0, 2] + v7[0, 3] + v7[0, 4] + v7[0, 5] + v7[0, 6] + v7[0, 7] + v7[0, 8] + v7[0, 9] + v7[0, 10] + v7[0, 11] + v7[0, 12] + v7[0, 13] + v7[0, 14] + v7[0, 15];
    v8[1] := v6[1] + v7[1, 0] + v7[1, 1] + v7[1, 2] + v7[1, 3] + v7[1, 4] + v7[1, 5] + v7[1, 6] + v7[1, 7] + v7[1, 8] + v7[1, 9] + v7[1, 10] + v7[1, 11] + v7[1, 12] + v7[1, 13] + v7[1, 14] + v7[1, 15];
    v8[2] := v6[2] + v7[2, 0] + v7[2, 1] + v7[2, 2] + v7[2, 3] + v7[2, 4] + v7[2, 5] + v7[2, 6] + v7[2, 7] + v7[2, 8] + v7[2, 9] + v7[2, 10] + v7[2, 11] + v7[2, 12] + v7[2, 13] + v7[2, 14] + v7[2, 15];
